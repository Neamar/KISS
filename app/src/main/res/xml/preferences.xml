<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    app:title="@string/activity_setting">
    <PreferenceScreen
        app:key="history_category"
        app:summary="@string/history_settings_summary"
        app:title="@string/title_history">
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:dialogMessage="@string/reset_warn"
            app:key="reset-history"
            app:title="@string/reset_name" />
        <EditTextPreference
            android:inputType="number"
            app:defaultValue="20"
            app:key="number-of-display-elements"
            app:title="@string/number_of_display_items"
            app:useSimpleSummaryProvider="true" />
        <ListPreference
            app:defaultValue="recency"
            app:entries="@array/historyModeEntries"
            app:entryValues="@array/historyModeValues"
            app:key="history-mode"
            app:summary="@string/history_mode_desc"
            app:title="@string/history_mode_name" />
        <fr.neamar.kiss.preference.FreezeHistorySwitch
            app:defaultValue="false"
            app:key="freeze-history"
            app:summary="@string/freeze_history_summary"
            app:title="@string/freeze_history_name" />
        <PreferenceCategory
            app:key="alternate-history-inputs-section"
            app:title="@string/alternate_history_inputs">
            <SwitchPreference
                app:defaultValue="false"
                app:key="enable-phone-history"
                app:title="@string/enable_phone" />
            <SwitchPreference
                app:defaultValue="true"
                app:key="enable-app-history"
                app:title="@string/enable_app" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="enable-notification-history"
                app:title="@string/enable_notification_history" />
        </PreferenceCategory>
    </PreferenceScreen>
    <PreferenceScreen
        app:key="history_favorites"
        app:summary="@string/history_favorites_summary"
        app:title="@string/title_favorites">
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:dialogMessage="@string/reset_favorites_warn"
            app:key="reset-favorites"
            app:title="@string/reset_favorites_name" />
        <SwitchPreference
            app:defaultValue="false"
            app:key="exclude-favorites-apps"
            app:title="@string/exclude_favorites_apps" />
        <SwitchPreference
            app:defaultValue="true"
            app:key="exclude-favorites-history"
            app:title="@string/exclude_favorites_history" />
        <fr.neamar.kiss.preference.TagsSelectPreference
            app:defaultValue="@array/favTagsDefault"
            app:key="pref-fav-tags-list"
            app:title="@string/pref_fav_tags_select" />
        <PreferenceCategory app:title="@string/misc">
            <SwitchPreference
                app:defaultValue="true"
                app:key="enable-favorites-bar"
                app:summaryOff="@string/enable_favorites_bar_summary_off"
                app:summaryOn="@string/enable_favorites_bar_summary_on"
                app:title="@string/enable_favorites_bar" />
            <SwitchPreference
                app:defaultValue="false"
                app:dependency="enable-favorites-bar"
                app:key="large-favorites-bar"
                app:title="@string/large_favorites_bar" />
            <SwitchPreference
                app:defaultValue="true"
                app:key="transparent-favorites"
                app:title="@string/transparent_favorites_bar" />
        </PreferenceCategory>
    </PreferenceScreen>
    <PreferenceScreen
        app:key="ui-holder"
        app:summary="@string/user_interface_summary"
        app:title="@string/title_ui">
        <ListPreference
            app:defaultValue="transparent"
            app:entries="@array/themesEntries"
            app:entryValues="@array/themesValues"
            app:key="theme"
            app:title="@string/theme_name"
            app:useSimpleSummaryProvider="true" />
        <PreferenceScreen
            app:key="theme-customisation"
            app:title="@string/theme_customisation">
            <ListPreference
                app:defaultValue="default"
                app:entries="@array/shadowEntries"
                app:entryValues="@array/shadowValues"
                app:key="theme-shadow"
                app:title="@string/theme_shadow"
                app:useSimpleSummaryProvider="true" />
            <ListPreference
                app:defaultValue="default"
                app:entries="@array/separatorEntries"
                app:entryValues="@array/separatorValues"
                app:key="theme-separator"
                app:title="@string/theme_separator"
                app:useSimpleSummaryProvider="true" />
            <ListPreference
                app:defaultValue="default"
                app:entries="@array/resultColorEntries"
                app:entryValues="@array/resultColorValues"
                app:key="theme-result-color"
                app:title="@string/theme_result_color"
                app:useSimpleSummaryProvider="true" />
            <ListPreference
                app:defaultValue="default"
                app:entries="@array/wallpaperEntries"
                app:entryValues="@array/wallpaperValues"
                app:key="theme-wallpaper"
                app:title="@string/theme_wallpaper"
                app:useSimpleSummaryProvider="true" />
            <ListPreference
                app:defaultValue="default"
                app:entries="@array/barColorEntries"
                app:entryValues="@array/barColorValues"
                app:key="theme-bar-color"
                app:title="@string/theme_bar_color"
                app:useSimpleSummaryProvider="true" />
            <SwitchPreference
                app:key="transparent-search"
                app:title="@string/transparent_search_bar" />
        </PreferenceScreen>
        <PreferenceCategory
            app:key="results-section"
            app:title="@string/search_results_options">
            <ListPreference
                app:defaultValue="default"
                app:entries="@array/resultsSizeEntries"
                app:entryValues="@array/resultsSizeValues"
                app:key="results-size"
                app:title="@string/results_size"
                app:useSimpleSummaryProvider="true" />
            <MultiSelectListPreference
                app:defaultValue="@array/resultHighlightingDefault"
                app:entries="@array/resultHighlightingEntries"
                app:entryValues="@array/resultHighlightingValues"
                app:key="pref-result-highlighting"
                app:summary="@string/pref_result_highlighting_summary"
                app:title="@string/pref_result_highlighting" />
        </PreferenceCategory>
        <PreferenceCategory
            app:key="colors-section"
            app:title="@string/colors">
            <fr.neamar.kiss.preference.ColorPreference
                app:dialogTitle="@string/color_picker_default_title"
                app:key="primary-color"
                app:title="@string/main_color" />
            <fr.neamar.kiss.preference.ColorPreference
                app:dialogTitle="@string/color_picker_default_title"
                app:key="notification-bar-color"
                app:title="@string/notification_bar_color" />
            <SwitchPreference
                app:key="black-notification-icons"
                app:title="@string/black_notification_icons" />
        </PreferenceCategory>
        <PreferenceCategory
            app:key="icons-section"
            app:title="@string/icons_category">
            <fr.neamar.kiss.preference.IconPackSelectPreference
                app:key="icons-pack"
                app:title="@string/icons_pack_name"
                app:useSimpleSummaryProvider="true" />

            <ListPreference
                app:defaultValue="0"
                app:entries="@array/adaptiveEntries"
                app:entryValues="@array/adaptiveValues"
                app:key="adaptive-shape"
                app:summary="@string/adaptive_shape_summary"
                app:title="@string/adaptive_shape_name" />

            <SwitchPreference
                app:defaultValue="true"
                app:disableDependentsState="true"
                app:key="force-adaptive"
                app:summary="@string/force_adaptive_summary"
                app:title="@string/force_adaptive" />

            <SwitchPreference
                app:defaultValue="false"
                app:dependency="force-adaptive"
                app:key="force-shape"
                app:summary="@string/force_shape_summary"
                app:title="@string/force_shape" />

            <SwitchPreference
                app:defaultValue="true"
                app:disableDependentsState="true"
                app:key="contact-pack-mask"
                app:summary="@string/contact_pack_mask_summary"
                app:title="@string/contact_pack_mask" />

            <ListPreference
                app:defaultValue="0"
                app:dependency="contact-pack-mask"
                app:entries="@array/adaptiveEntriesForContacts"
                app:entryValues="@array/adaptiveValues"
                app:key="contacts-shape"
                app:summary="@string/contacts_shape_summary"
                app:title="@string/contacts_shape" />

            <SwitchPreference
                app:defaultValue="false"
                app:key="themed-icons"
                app:summary="@string/icons_themed_summary"
                app:title="@string/icons_themed_name" />
            <SwitchPreference
                app:defaultValue="true"
                app:key="subicon-visible"
                app:title="@string/show_subicons" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="icons-hide"
                app:summary="@string/icons_hide_desc"
                app:title="@string/icons_hide_main" />
        </PreferenceCategory>
        <PreferenceCategory app:title="@string/misc">
            <SwitchPreference
                app:defaultValue="false"
                app:key="pref-rounded-list"
                app:title="@string/rounded_list" />
            <SwitchPreference
                app:defaultValue="true"
                app:key="pref-rounded-bars"
                app:title="@string/rounded_bars" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="pref-swap-kiss-button-with-menu"
                app:title="@string/swap_kiss_button_with_menu" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="large-result-list-margins"
                app:title="@string/large_result_list_margins" />
        </PreferenceCategory>
    </PreferenceScreen>
    <PreferenceScreen
        app:key="ux-holder"
        app:summary="@string/user_experience_summary"
        app:title="@string/title_ux">
        <PreferenceCategory app:title="@string/keyboard_options">
            <SwitchPreference
                app:defaultValue="false"
                app:key="display-keyboard"
                app:title="@string/keyboard_name" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="enable-suggestions-keyboard"
                app:title="@string/keyboard_suggestions" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="hide-keyboard"
                app:title="@string/keyboard_hide" />
        </PreferenceCategory>
        <PreferenceCategory
            app:key="history-hide-section"
            app:title="@string/history_hide_name">
            <SwitchPreference
                app:defaultValue="false"
                app:key="history-hide"
                app:summary="@string/history_hide_desc"
                app:title="@string/history_hide_name" />
            <SwitchPreference
                app:defaultValue="false"
                app:dependency="history-hide"
                app:key="history-onclick"
                app:title="@string/history_onclick_name" />
            <SwitchPreference
                app:defaultValue="false"
                app:dependency="history-hide"
                app:key="history-onkeyboard"
                app:summary="@string/history_onkeyboard_desc"
                app:title="@string/history_onkeyboard_name" />
            <SwitchPreference
                app:defaultValue="false"
                app:dependency="history-hide"
                app:key="favorites-hide"
                app:title="@string/favorites_hide" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="pref-hide-navbar"
                app:summary="@string/pref_hide_navbar_desc"
                app:title="@string/pref_hide_navbar" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="pref-hide-statusbar"
                app:summary="@string/pref_hide_statusbar_desc"
                app:title="@string/pref_hide_statusbar" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="pref-hide-circle"
                app:summary="@string/pref_hide_circle_desc"
                app:title="@string/pref_hide_circle" />
        </PreferenceCategory>
        <PreferenceCategory
            app:key="gestures-holder"
            app:title="@string/gestures">
            <ListPreference
                app:defaultValue="display-keyboard"
                app:entries="@array/gestureEntries"
                app:entryValues="@array/gestureValues"
                app:key="gesture-up"
                app:title="@string/gesture_up_name"
                app:useSimpleSummaryProvider="true" />
            <fr.neamar.kiss.preference.LaunchPojoSelectPreference
                app:dependency="gesture-up"
                app:key="gesture-up-launch-id"
                app:title="@string/gesture_launch_pojo"
                app:useSimpleSummaryProvider="true" />
            <ListPreference
                app:defaultValue="display-notifications"
                app:entries="@array/gestureEntries"
                app:entryValues="@array/gestureValues"
                app:key="gesture-down"
                app:title="@string/gesture_down_name"
                app:useSimpleSummaryProvider="true" />
            <fr.neamar.kiss.preference.LaunchPojoSelectPreference
                app:dependency="gesture-down"
                app:key="gesture-down-launch-id"
                app:title="@string/gesture_launch_pojo"
                app:useSimpleSummaryProvider="true" />
            <ListPreference
                app:defaultValue="display-apps"
                app:entries="@array/gestureEntries"
                app:entryValues="@array/gestureValues"
                app:key="gesture-left"
                app:title="@string/gesture_left_name"
                app:useSimpleSummaryProvider="true" />
            <fr.neamar.kiss.preference.LaunchPojoSelectPreference
                app:dependency="gesture-left"
                app:key="gesture-left-launch-id"
                app:title="@string/gesture_launch_pojo"
                app:useSimpleSummaryProvider="true" />
            <ListPreference
                app:defaultValue="display-apps"
                app:entries="@array/gestureEntries"
                app:entryValues="@array/gestureValues"
                app:key="gesture-right"
                app:title="@string/gesture_right_name"
                app:useSimpleSummaryProvider="true" />
            <fr.neamar.kiss.preference.LaunchPojoSelectPreference
                app:dependency="gesture-right"
                app:key="gesture-right-launch-id"
                app:title="@string/gesture_launch_pojo"
                app:useSimpleSummaryProvider="true" />
            <ListPreference
                app:defaultValue="display-apps"
                app:entries="@array/gestureEntries"
                app:entryValues="@array/gestureValues"
                app:key="gesture-long-press"
                app:title="@string/gesture_long_press_name"
                app:useSimpleSummaryProvider="true" />
            <fr.neamar.kiss.preference.LaunchPojoSelectPreference
                app:dependency="gesture-long-press"
                app:key="gesture-long-press-launch-id"
                app:title="@string/gesture_launch_pojo"
                app:useSimpleSummaryProvider="true" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="double-tap"
                app:title="@string/double_tap_to_lock" />
        </PreferenceCategory>
        <PreferenceCategory app:title="@string/tags_category">
            <SwitchPreference
                app:defaultValue="true"
                app:key="tags-visible"
                app:title="@string/tags_visible" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="pref-fav-tags-drawable"
                app:summary="@string/pref_fav_tags_drawable_desc"
                app:title="@string/pref_fav_tags_drawable" />
            <PreferenceScreen
                app:key="customize-tags-menu"
                app:title="@string/screen_toggle_tags">
                <SwitchPreference
                    app:defaultValue="false"
                    app:key="pref-tags-menu"
                    app:title="@string/pref_tags_menu" />
                <SwitchPreference
                    app:defaultValue="false"
                    app:key="pref-show-untagged"
                    app:title="@string/pref_show_untagged" />
                <SwitchPreference
                    app:defaultValue="false"
                    app:key="pref-tags-menu-dismiss"
                    app:title="@string/pref_tags_menu_dismiss" />
                <fr.neamar.kiss.preference.TagsSelectPreference
                    app:defaultValue="@array/toggleTagsDefault"
                    app:key="pref-toggle-tags-list"
                    app:title="@string/pref_toggle_tags_select" />
            </PreferenceScreen>
            <ListPreference
                app:entries="@array/taggedResultSortModeEntries"
                app:entryValues="@array/taggedResultSortModeValues"
                app:key="tagged-result-sort-mode"
                app:summary="@string/tagged_result_sort_mode_desc"
                app:title="@string/tagged_result_sort_mode_name" />
        </PreferenceCategory>
        <PreferenceCategory app:title="@string/misc">
            <SwitchPreference
                app:defaultValue="false"
                app:key="force-portrait"
                app:title="@string/portrait_title" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="call-contact-on-click"
                app:title="@string/contacts_call_on_click" />
        </PreferenceCategory>
        <PreferenceScreen
            app:key="wallpaper-holder"
            app:title="@string/title_wallpaper">
            <SwitchPreference
                app:defaultValue="true"
                app:key="lwp-touch"
                app:title="@string/lwp_touch" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="lwp-drag"
                app:summary="@string/lwp_drag_desc"
                app:title="@string/lwp_drag" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="wp-drag-animate"
                app:summary="@string/wp_drag_animate_desc"
                app:title="@string/wp_drag_animate" />
            <SwitchPreference
                app:defaultValue="true"
                app:dependency="wp-drag-animate"
                app:key="wp-animate-center"
                app:summary="@string/wp_animate_center_desc"
                app:title="@string/wp_animate_center" />
            <SwitchPreference
                app:defaultValue="false"
                app:dependency="wp-drag-animate"
                app:key="wp-animate-sides"
                app:summary="@string/wp_animate_sides_desc"
                app:title="@string/wp_animate_sides" />
        </PreferenceScreen>
    </PreferenceScreen>
    <PreferenceScreen
        app:key="providers"
        app:summary="@string/providers_summary"
        app:title="@string/title_providers">
        <PreferenceCategory
            app:key="search-providers"
            app:title="@string/search_results_options">
            <SwitchPreference
                app:defaultValue="true"
                app:key="enable-contacts"
                app:title="@string/contacts_name" />
            <SwitchPreference
                app:defaultValue="true"
                app:key="enable-settings"
                app:title="@string/settings_name" />
            <SwitchPreference
                app:defaultValue="true"
                app:key="enable-timer"
                app:summary="@string/timer_description"
                app:title="@string/timer_name" />
            <SwitchPreference
                app:defaultValue="true"
                app:key="enable-shortcuts"
                app:title="@string/shortcuts_name" />
            <fr.neamar.kiss.preference.DialogShowingPreference
                app:dialogMessage="@string/regenerate_shortcuts_desc"
                app:key="reset-shortcuts"
                app:title="@string/regenerate_shortcuts" />
            <SwitchPreference
                app:defaultValue="true"
                app:key="enable-search"
                app:title="@string/search_provider_toggle" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="enable-excluded-apps"
                app:title="@string/excluded_apps_toggle" />
        </PreferenceCategory>
        <PreferenceCategory
            app:key="web-providers"
            app:title="@string/search_name">
            <fr.neamar.kiss.preference.DefaultSearchProviderSelectPreference
                app:key="default-search-provider"
                app:title="@string/search_provider_default"
                app:useSimpleSummaryProvider="true" />
            <fr.neamar.kiss.preference.SelectCustomSearchProvidersPreference
                app:key="selected-search-provider-names"
                app:title="@string/search_providers_title" />
            <fr.neamar.kiss.preference.DeleteCustomSearchProvidersPreference
                app:key="deleting-search-providers-names"
                app:title="@string/search_providers_delete" />
            <fr.neamar.kiss.preference.AddSearchProviderPreference
                app:key="custom-search-provider-add"
                app:title="@string/custom_search_provider" />
            <fr.neamar.kiss.preference.DialogShowingPreference
                app:dialogMessage="@string/search_provider_reset_desc"
                app:key="reset-search-providers"
                app:title="@string/search_provider_reset" />
        </PreferenceCategory>
        <PreferenceCategory app:title="@string/misc">
            <SwitchPreference
                app:defaultValue="false"
                app:key="always-default-web-search-on-enter"
                app:title="@string/always_default_web_search_on_enter" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="large-search-bar"
                app:title="@string/large_search_bar" />
            <SwitchPreference
                app:defaultValue="false"
                app:key="pref-hide-search-bar-hint"
                app:title="@string/hide_search_bar_hint" />
        </PreferenceCategory>
    </PreferenceScreen>
    <PreferenceScreen
        app:key="exclude_apps_category"
        app:summary="@string/ui_excluded_apps_dialog_title"
        app:title="@string/settings_excluded_apps">
        <Preference
            app:fragment="fr.neamar.kiss.ExcludeAppSettingsFragment"
            app:key="edit-excluded-apps"
            app:summary="@string/ui_excluded_apps_dialog_title"
            app:title="@string/ui_excluded_apps" />
        <Preference
            app:fragment="fr.neamar.kiss.ExcludeAppSettingsFragment"
            app:key="edit-excluded-from-history-apps"
            app:summary="@string/ui_excluded_apps_dialog_title"
            app:title="@string/ui_excluded_from_history_apps" />
        <Preference
            app:fragment="fr.neamar.kiss.ExcludeAppSettingsFragment"
            app:key="edit-excluded-app-shortcuts"
            app:summary="@string/ui_excluded_apps_dialog_title"
            app:title="@string/ui_excluded_from_shortcuts_apps" />
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:dialogMessage="@string/reset_excluded_apps_warn"
            app:key="reset-excluded-apps"
            app:title="@string/reset_excluded_apps_name" />
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:dialogMessage="@string/reset_excluded_from_history_apps_warn"
            app:key="reset-excluded-from-history-apps"
            app:title="@string/reset_excluded_from_history_apps_name" />
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:dialogMessage="@string/reset_excluded_app_shortcuts_warn"
            app:key="reset-excluded-app-shortcuts"
            app:title="@string/reset_excluded_app_shortcuts_name" />
        />
    </PreferenceScreen>
    <PreferenceScreen
        app:key="importexport"
        app:title="@string/title_import_export">
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:dialogMessage="@string/clipboard_warning_dialog"
            app:key="export-settings"
            app:title="@string/export_settings" />
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:dialogMessage="@string/import_settings_dialog"
            app:key="import-settings"
            app:title="@string/import_settings" />
    </PreferenceScreen>
    <PreferenceScreen
        app:key="advanced"
        app:title="@string/title_advanced">
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:defaultValue="true"
            app:dialogMessage="@string/notification_dialog"
            app:key="enable-notifications"
            app:title="@string/notification_support" />
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:dialogMessage="@string/default_launcher_warn"
            app:key="default-launcher"
            app:title="@string/default_launcher_title" />
        <fr.neamar.kiss.preference.MimeTypeSelectPreference
            app:defaultValue="@array/contactMimeTypesDefault"
            app:key="selected-contact-mime-types"
            app:summary="@string/contact_mime_types_summary"
            app:title="@string/contact_mime_types_title" />
        <SwitchPreference
            app:defaultValue="false"
            app:key="use-fuzzy-score-v1"
            app:title="Use legacy fuzzy search algorithm" />
        <fr.neamar.kiss.preference.RootModeSwitch
            app:defaultValue="false"
            app:key="root-mode"
            app:summary="@string/root_mode_desc"
            app:title="@string/root_mode_name" />
        <fr.neamar.kiss.preference.DialogShowingPreference
            app:dialogMessage="@string/restart_warn"
            app:key="restart"
            app:summary="@string/restart_desc"
            app:title="@string/restart_name" />
    </PreferenceScreen>
    <Preference
        app:key="rate-app"
        app:title="@string/rate_the_app" />
</PreferenceScreen>
